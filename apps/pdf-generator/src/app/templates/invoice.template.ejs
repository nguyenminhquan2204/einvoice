<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            padding: 40px;
            color: #333;
            font-size: 14px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #4f46e5;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .company h1 {
            color: #4f46e5;
            font-size: 32px;
            margin-bottom: 8px;
        }

        .company p {
            color: #666;
        }

        .status {
            text-align: right;
        }

        .status span {
            display: inline-block;
            padding: 8px 16px;
            border-radius: 20px;
            background: #4f46e5;
            color: white;
            font-weight: bold;
        }

        .section-title {
            font-size: 18px;
            margin-bottom: 12px;
            color: #4f46e5;
        }

        .client {
            background: #f8fafc;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
        }

        .client p {
            margin: 6px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        thead {
            background: #4f46e5;
            color: white;
        }

        th,
        td {
            padding: 12px;
            border: 1px solid #ddd;
        }

        th {
            text-align: left;
        }

        td:last-child,
        th:last-child,
        td:nth-last-child(2),
        td:nth-last-child(3),
        td:nth-last-child(4) {
            text-align: right;
        }

        tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .summary {
            width: 350px;
            margin-left: auto;
        }

        .summary table td {
            border: none;
            padding: 10px 0;
        }

        .summary table tr:last-child td {
            border-top: 2px solid #4f46e5;
            font-size: 18px;
            font-weight: bold;
            color: #4f46e5;
        }

        .footer {
            margin-top: 60px;
            text-align: center;
            color: #888;
            font-size: 12px;
            border-top: 1px solid #ddd;
            padding-top: 20px;
        }
    </style>
</head>

<body>

<div class="header">
    <div class="company">
        <h1>INVOICE</h1>
        <p>Generated by E-Invoice System</p>
    </div>

    <div class="status">
        <span><%= status %></span>
    </div>
</div>

<div class="client">
    <div class="section-title">
        Bill To
    </div>

    <p><strong>Name:</strong> <%= client.name %></p>
    <p><strong>Email:</strong> <%= client.email %></p>
    <p><strong>Address:</strong> <%= client.address %></p>
</div>

<div class="section-title">
    Invoice Items
</div>

<table>
    <thead>
    <tr>
        <th>#</th>
        <th>Product</th>
        <th>Qty</th>
        <th>Unit Price</th>
        <th>VAT</th>
        <th>Total</th>
    </tr>
    </thead>

    <tbody>

    <% items.forEach((item,index)=> { %>

        <tr>
            <td><%= index + 1 %></td>

            <td>
                <strong><%= item.name %></strong><br>
                <small><%= item.productId %></small>
            </td>

            <td><%= item.quantity %></td>

            <td>
                $<%= item.unitPrice.toFixed(2) %>
            </td>

            <td>
                <%= item.vatRate %>%
            </td>

            <td>
                $<%= item.total.toFixed(2) %>
            </td>
        </tr>

    <% }) %>

    </tbody>
</table>

<div class="summary">

    <table>

        <tr>
            <td>Subtotal</td>
            <td style="text-align:right;">
                $<%= subtotal.toFixed(2) %>
            </td>
        </tr>

        <tr>
            <td>VAT</td>
            <td style="text-align:right;">
                $<%= vatAmount.toFixed(2) %>
            </td>
        </tr>

        <tr>
            <td>Total</td>
            <td style="text-align:right;">
                $<%= totalAmount.toFixed(2) %>
            </td>
        </tr>

    </table>

</div>

<div class="footer">
    Thank you for your business ❤️
</div>

</body>
</html>